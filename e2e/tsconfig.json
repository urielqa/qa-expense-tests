{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["@playwright/test", "node"]
  },
  "include": [
    "playwright.config.ts",
    "pages/**/*.ts",
    "tests/**/*.ts",
    "helpers/**/*.ts",
    "resources/**/*.ts",
    "data/**/*.ts"
  ]
}
